---
/**
 * Giscus-powered comments, scoped to our GitHub Discussions.
 *
 * Wiring (done):
 *   - Repo: aditdhn/paramai-blog, Discussions enabled, visibility public
 *   - Category: "Blog Comments" (dedicated Announcement-type category
 *     created via giscus.app so only maintainers + Giscus can seed
 *     threads — random users can't pollute the discussion space)
 *   - IDs taken from giscus.app's generated snippet — hardcoded below.
 *
 * For Giscus to actually light up, two more prerequisites must hold:
 *   1. The repository must be PUBLIC. Giscus can read a private repo's
 *      discussions via the app, but visitors can't, so comments won't
 *      render in the browser. If you keep the repo private, Giscus shows
 *      an empty state.
 *   2. The giscus GitHub App must be installed on the repo:
 *      https://github.com/apps/giscus
 *
 * Giscus uses GitHub OAuth to post, which requires a GitHub account (age
 * 13+ per GitHub's ToS). Combined with our own 16+ notice, that's our
 * age gate.
 */
const {
  repo = 'aditdhn/paramai-blog',
  repoId = 'R_kgDOR9sX3Q',
  category = 'Blog Comments',
  categoryId = 'DIC_kwDOR9sX3c4C6byf',
  mapping = 'pathname',
} = Astro.props
---

<section class="mt-16 rounded-2xl border border-ink-200 bg-ink-50/50 p-6 dark:border-ink-800 dark:bg-ink-900/50">
  <div class="mb-5 flex flex-wrap items-center justify-between gap-3">
    <div>
      <h2 class="text-xl font-bold">Join the conversation</h2>
      <p class="mt-1 text-sm text-ink-600 dark:text-ink-300">
        Share what you're thinking, ask a question, or tell us what we got
        wrong. Comments are powered by GitHub Discussions.
      </p>
    </div>
    <a
      href="/community-guidelines/"
      class="inline-flex items-center gap-1.5 rounded-full border border-ink-300 bg-white px-3 py-1.5 text-xs font-medium text-ink-700 hover:border-brand-500 hover:text-brand-600 dark:border-ink-700 dark:bg-ink-900 dark:text-ink-200 dark:hover:border-brand-400 dark:hover:text-brand-400"
    >
      Community guidelines
    </a>
  </div>

  {/* Safety banner — visible before the comments load */}
  <div
    role="note"
    class="mb-4 rounded-xl border border-amber-300/60 bg-amber-50 p-4 text-sm text-amber-900 dark:border-amber-500/40 dark:bg-amber-950/40 dark:text-amber-200"
  >
    <p class="font-semibold">Before you post:</p>
    <ul class="mt-1.5 list-disc space-y-1 pl-5">
      <li>You must be <strong>16 or older</strong> to comment.</li>
      <li>
        Never share personal info — phone, email, address, school name,
        full name. Keep conversations public.
      </li>
      <li>
        Be kind. Harassment, hate, and spam get removed and reported.
      </li>
      <li>
        See something that breaks these rules? Use the <strong>Report</strong>
        button next to any comment or email
        <a href="mailto:grievance@paramai.in" class="underline hover:no-underline">grievance@paramai.in</a>.
      </li>
    </ul>
  </div>

  {/* "New to GitHub?" hint — reduces signup friction for non-coders.
      Rendered above Giscus so readers see it before the login button. */}
  <details class="mb-6 rounded-xl border border-ink-200 bg-white/70 p-4 text-sm dark:border-ink-800 dark:bg-ink-900/70">
    <summary class="cursor-pointer font-semibold text-ink-800 dark:text-ink-100">
      New to GitHub? It's free and takes 30 seconds.
    </summary>
    <div class="mt-3 space-y-2 text-ink-600 dark:text-ink-300">
      <p>
        We use GitHub as the login for comments because it's the cleanest way
        to keep the conversation safe — real accounts, real moderation, no spam
        bots. You don't need to know how to code. You don't need a phone number.
        You just need an email.
      </p>
      <ol class="list-decimal space-y-1 pl-5">
        <li>
          Click <strong>Sign in with GitHub</strong> below. A new tab opens.
        </li>
        <li>
          Click <strong>Create an account</strong> on GitHub's page. Enter your
          email, pick a password, pick a username (your display name on
          comments). Hit continue.
        </li>
        <li>
          GitHub sends a verification code to your email. Paste it in.
        </li>
        <li>
          You're in. Come back to this tab and click <strong>Sign in with
          GitHub</strong> once more to authorise Giscus — then post your first
          comment.
        </li>
      </ol>
      <p class="text-xs text-ink-500 dark:text-ink-400">
        You can use GitHub for anything else later if you want, or just keep
        the account for commenting here. Your choice.
      </p>
    </div>
  </details>

  <script
    is:inline
    src="https://giscus.app/client.js"
    data-repo={repo}
    data-repo-id={repoId}
    data-category={category}
    data-category-id={categoryId}
    data-mapping={mapping}
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="bottom"
    data-theme="preferred_color_scheme"
    data-lang="en"
    data-loading="lazy"
    crossorigin="anonymous"
    async
  ></script>
</section>
