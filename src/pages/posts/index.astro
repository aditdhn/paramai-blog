---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'
import { readingTime } from '@/lib/readingTime'

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
)
---

<BaseLayout
  title="All posts | ParamAI Blog"
  description="Editorial posts on assessment science, career discovery, and the future of work in India."
>
  <section class="mx-auto max-w-4xl px-6 py-16">
    <p class="text-xs font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">
      Posts
    </p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">Posts</h1>
    <p class="mt-4 max-w-2xl text-lg text-ink-600 dark:text-ink-300">
      Editorial posts on assessment science, career discovery, and the future
      of work in India. Opinionated but honest.
    </p>

    {
      posts.length === 0 ? (
        <p class="mt-10 text-ink-600 dark:text-ink-300">No posts yet — check back soon.</p>
      ) : (
        <ul class="mt-12 space-y-10">
          {posts.map((p) => (
            <li>
              <a
                href={`/posts/${p.slug}/`}
                class="group block rounded-2xl border border-transparent p-6 -mx-6 transition-colors hover:border-ink-200 hover:bg-ink-50/50 dark:hover:border-ink-800 dark:hover:bg-ink-900/50"
              >
                <p class="flex items-center gap-2 text-xs text-ink-500 dark:text-ink-400">
                  <span>{p.data.pubDate.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                  <span>·</span>
                  <span>{readingTime(p.body)}</span>
                </p>
                <h2 class="mt-2 text-2xl font-bold leading-tight group-hover:text-brand-600 dark:group-hover:text-brand-400">
                  {p.data.title}
                </h2>
                <p class="mt-2 text-ink-600 dark:text-ink-300">{p.data.description}</p>
                <p class="mt-4 text-sm font-semibold text-brand-600 dark:text-brand-400">
                  Read the post →
                </p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
