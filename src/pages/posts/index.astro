---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
)
---

<BaseLayout
  title="All posts | ParamAI Blog"
  description="Editorial posts on assessment science, career discovery, and the future of work in India."
>
  <h1 class="text-3xl font-bold text-brand-900">All posts</h1>

  {
    posts.length === 0 ? (
      <p class="mt-4 text-slate-600">No posts yet — check back soon.</p>
    ) : (
      <ul class="mt-8 space-y-6">
        {posts.map((p) => (
          <li>
            <a href={`/posts/${p.slug}/`} class="block group">
              <h2 class="text-xl font-semibold text-brand-900 group-hover:text-brand-600">
                {p.data.title}
              </h2>
              <p class="mt-1 text-sm text-slate-600">{p.data.description}</p>
              <p class="mt-1 text-xs text-slate-400">
                {p.data.pubDate.toLocaleDateString('en-IN', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
