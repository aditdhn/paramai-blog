---
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, APP_URL } from '@/consts'

interface Props {
  title?: string
  description?: string
  canonical?: string
  ogImage?: string
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  canonical,
  ogImage = '/og-default.png',
} = Astro.props

const canonicalURL = canonical ?? new URL(Astro.url.pathname, SITE_URL).toString()
const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, SITE_URL).toString()} />
    <meta property="og:site_name" content="ParamAI Blog" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, SITE_URL).toString()} />

    <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    {/* Dark mode: apply saved preference before first paint to avoid flash. */}
    <script is:inline>
      ;(() => {
        const saved = localStorage.getItem('theme')
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark')
        }
      })()
    </script>
  </head>
  <body
    class="min-h-screen bg-white font-sans text-ink-900 antialiased transition-colors duration-300 dark:bg-ink-950 dark:text-ink-100"
  >
    <header class="sticky top-0 z-40 border-b border-ink-200/70 bg-white/85 backdrop-blur-lg dark:border-ink-800/70 dark:bg-ink-950/85">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="group flex items-center gap-2 text-lg font-bold">
          <span
            class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-brand-600 to-accent-500 text-white shadow-lg shadow-brand-500/30 transition-transform group-hover:scale-105"
          >
            P
          </span>
          <span class="text-ink-900 dark:text-ink-50">ParamAI Blog</span>
        </a>

        <nav class="flex items-center gap-1 text-sm font-medium sm:gap-2">
          <a
            href="/sectors/"
            class:list={[
              'rounded-lg px-3 py-2 transition-colors hover:bg-ink-100 dark:hover:bg-ink-800',
              currentPath.startsWith('/sectors') && 'text-brand-600 dark:text-brand-400',
            ]}
          >
            Sectors
          </a>
          <a
            href="/posts/"
            class:list={[
              'rounded-lg px-3 py-2 transition-colors hover:bg-ink-100 dark:hover:bg-ink-800',
              currentPath.startsWith('/posts') && 'text-brand-600 dark:text-brand-400',
            ]}
          >
            Posts
          </a>
          <a
            href="/community/"
            class:list={[
              'hidden rounded-lg px-3 py-2 transition-colors hover:bg-ink-100 sm:inline-flex dark:hover:bg-ink-800',
              currentPath.startsWith('/community') && 'text-brand-600 dark:text-brand-400',
            ]}
          >
            Community
          </a>

          <button
            type="button"
            id="theme-toggle"
            aria-label="Toggle dark mode"
            class="ml-1 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-ink-200 text-ink-600 transition-colors hover:bg-ink-100 dark:border-ink-700 dark:text-ink-300 dark:hover:bg-ink-800"
          >
            <svg class="block h-4 w-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" /></svg>
            <svg class="hidden h-4 w-4 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" /></svg>
          </button>

          <a
            href={APP_URL}
            class="ml-2 hidden rounded-full bg-gradient-to-r from-brand-600 to-brand-500 px-4 py-2 font-semibold text-white shadow-md shadow-brand-600/25 transition-all hover:shadow-lg hover:shadow-brand-600/40 md:inline-flex"
            rel="noopener"
          >
            Take the assessment →
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-24 border-t border-ink-200/70 bg-ink-50/50 dark:border-ink-800/70 dark:bg-ink-900/50">
      <div class="mx-auto max-w-6xl px-6 py-12">
        <div class="grid gap-10 md:grid-cols-4">
          <div class="md:col-span-2">
            <div class="flex items-center gap-2">
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-brand-600 to-accent-500 text-white">
                P
              </span>
              <span class="text-lg font-bold">ParamAI Blog</span>
            </div>
            <p class="mt-3 max-w-md text-sm text-ink-600 dark:text-ink-300">
              Honest, research-backed writing on career discovery, assessment
              science, and the 41 sectors powering India's next decade of work.
              Built by the team behind <a href={APP_URL} class="text-brand-600 hover:underline dark:text-brand-400" rel="noopener">paramai.in</a>.
            </p>
          </div>

          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-ink-700 dark:text-ink-200">Explore</h3>
            <ul class="mt-4 space-y-2 text-sm text-ink-600 dark:text-ink-300">
              <li><a href="/sectors/" class="hover:text-brand-600 dark:hover:text-brand-400">All 41 sectors</a></li>
              <li><a href="/posts/" class="hover:text-brand-600 dark:hover:text-brand-400">All posts</a></li>
              <li><a href="/community/" class="hover:text-brand-600 dark:hover:text-brand-400">Community</a></li>
              <li><a href="/rss.xml" class="hover:text-brand-600 dark:hover:text-brand-400">RSS feed</a></li>
            </ul>
          </div>

          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-ink-700 dark:text-ink-200">Safety</h3>
            <ul class="mt-4 space-y-2 text-sm text-ink-600 dark:text-ink-300">
              <li><a href="/community-guidelines/" class="hover:text-brand-600 dark:hover:text-brand-400">Community guidelines</a></li>
              <li><a href="/grievance-officer/" class="hover:text-brand-600 dark:hover:text-brand-400">Grievance officer</a></li>
              <li><a href={`${APP_URL}/privacy`} class="hover:text-brand-600 dark:hover:text-brand-400" rel="noopener">Privacy policy</a></li>
              <li><a href={`${APP_URL}/terms`} class="hover:text-brand-600 dark:hover:text-brand-400" rel="noopener">Terms of service</a></li>
            </ul>
          </div>
        </div>

        <div class="mt-10 flex flex-col items-center justify-between gap-3 border-t border-ink-200/70 pt-6 text-xs text-ink-500 md:flex-row dark:border-ink-800/70">
          <p>&copy; {new Date().getFullYear()} ParamAI. Made in India, for the world.</p>
          <p>
            Assessment at
            <a href={APP_URL} class="font-medium text-brand-600 hover:underline dark:text-brand-400" rel="noopener">paramai.in</a>
          </p>
        </div>
      </div>
    </footer>

    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const root = document.documentElement
        const next = root.classList.contains('dark') ? 'light' : 'dark'
        root.classList.toggle('dark', next === 'dark')
        localStorage.setItem('theme', next)
      })
    </script>
  </body>
</html>
